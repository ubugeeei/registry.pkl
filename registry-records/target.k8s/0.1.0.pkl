amends "@target.core/FirstPartyRecord.pkl"

family = "target.k8s"
version = "0.1.0"
ecosystem = "k8s"

targets {
  "kustomization.yaml"
  "Chart.yaml"
  "values.yaml"
  "deployment.yaml"
  "service.yaml"
  "configmap.yaml"
  "pod.yaml"
  "statefulset.yaml"
  "daemonset.yaml"
  "job.yaml"
  "cronjob.yaml"
  "ingress.yaml"
  "networkpolicy.yaml"
  "secret.yaml"
  "persistentvolumeclaim.yaml"
}

formats {
  "yaml"
}

tags {
  "kubernetes"
  "kustomize"
  "helm"
  "infra"
}

description = "Typed Pkl modules for Kubernetes manifests — Kustomize and Helm."
