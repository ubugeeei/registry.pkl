/// A typed authoring surface for Koyeb's `koyeb.yaml`.
///
/// Koyeb's app config is YAML — a top-level `services` list plus
/// shared databases/regions. This module covers the common service
/// shape (build/docker, instance, ports, env, scaling, healthchecks).
///
/// Reference: https://www.koyeb.com/docs/build-and-deploy/build-from-git
module target.deploy.koyeb.Koyeb

import "@target.core/Maps.pkl" as Maps

class Build {
  buildpack: Mapping<String, Any>? = null
  dockerfile: String? = null
  dockerContext: String? = null
  dockerTarget: String? = null
  dockerArgs: Mapping<String, String> = new Mapping {}
  extra: Mapping<String, Any> = new Mapping {}
}

class Port {
  port: Int
  protocol: ("http"|"http2"|"tcp")
}

class Route {
  path: String
  port: Int
}

class HealthCheck {
  http: Mapping<String, Any>? = null
  tcp: Mapping<String, Any>? = null
  grace_period: Int? = null
  interval: Int? = null
  restart_limit: Int? = null
  timeout: Int? = null
}

class Scaling {
  min: Int? = null
  max: Int? = null
  targets: Listing<Mapping<String, Any>> = new Listing {}
}

class Env {
  key: String
  value: String? = null
  secret: String? = null
  scopes: Listing<String> = new Listing {}
}

class Service {
  name: String
  type: ("web"|"worker") = "web"
  regions: Listing<String> = new Listing {}
  instance_types: Listing<String> = new Listing {}
  ports: Listing<Port> = new Listing {}
  routes: Listing<Route> = new Listing {}
  env: Listing<Env> = new Listing {}
  scaling: Scaling? = null
  health_checks: Listing<HealthCheck> = new Listing {}
  git: Mapping<String, Any>? = null
  docker: Mapping<String, Any>? = null
  build: Build? = null
  privileged: Boolean? = null
  skip_cache: Boolean? = null
  run_command: String? = null
  extra: Mapping<String, Any> = new Mapping {}
}

services: Listing<Service> = new Listing {}
databases: Listing<Mapping<String, Any>> = new Listing {}
extra: Mapping<String, Any> = new Mapping {}

local function renderPort(value: Port) =
  new Mapping<String, Any> {
    ["port"] = value.port
    ["protocol"] = value.protocol
  }.toMap()

local function renderRoute(value: Route) =
  new Mapping<String, Any> {
    ["path"] = value.path
    ["port"] = value.port
  }.toMap()

local function renderEnv(value: Env) =
  new Mapping<String, Any> {
    ["key"] = value.key
    when (value.value != null) { ["value"] = value.value }
    when (value.secret != null) { ["secret"] = value.secret }
    when (!value.scopes.toList().isEmpty) {
      ["scopes"] = value.scopes.toList()
    }
  }.toMap()

local function renderHealthCheck(value: HealthCheck) =
  new Mapping<String, Any> {
    when (value.http != null) { ["http"] = value.http.toMap() }
    when (value.tcp != null) { ["tcp"] = value.tcp.toMap() }
    when (value.grace_period != null) {
      ["grace_period"] = value.grace_period
    }
    when (value.interval != null) { ["interval"] = value.interval }
    when (value.restart_limit != null) {
      ["restart_limit"] = value.restart_limit
    }
    when (value.timeout != null) { ["timeout"] = value.timeout }
  }.toMap()

local function renderScaling(value: Scaling) =
  new Mapping<String, Any> {
    when (value.min != null) { ["min"] = value.min }
    when (value.max != null) { ["max"] = value.max }
    when (!value.targets.toList().isEmpty) {
      ["targets"] = value.targets.toList().map((m) -> m.toMap())
    }
  }.toMap()

local function renderBuild(value: Build) =
  Maps.withExtra(
    new Mapping<String, Any> {
      when (value.buildpack != null) {
        ["buildpack"] = value.buildpack.toMap()
      }
      when (value.dockerfile != null) {
        ["dockerfile"] = value.dockerfile
      }
      when (value.dockerContext != null) {
        ["docker_context"] = value.dockerContext
      }
      when (value.dockerTarget != null) {
        ["docker_target"] = value.dockerTarget
      }
      when (!value.dockerArgs.toMap().isEmpty) {
        ["docker_args"] = value.dockerArgs.toMap()
      }
    },
    value.extra,
  )

local function renderService(value: Service) =
  Maps.withExtra(
    new Mapping<String, Any> {
      ["name"] = value.name
      ["type"] = value.type
      when (!value.regions.toList().isEmpty) {
        ["regions"] = value.regions.toList()
      }
      when (!value.instance_types.toList().isEmpty) {
        ["instance_types"] = value.instance_types.toList()
      }
      when (!value.ports.toList().isEmpty) {
        ["ports"] = value.ports.toList().map((p) -> renderPort(p))
      }
      when (!value.routes.toList().isEmpty) {
        ["routes"] = value.routes.toList().map((r) -> renderRoute(r))
      }
      when (!value.env.toList().isEmpty) {
        ["env"] = value.env.toList().map((e) -> renderEnv(e))
      }
      when (value.scaling != null) {
        ["scaling"] = renderScaling(value.scaling)
      }
      when (!value.health_checks.toList().isEmpty) {
        ["health_checks"] = value.health_checks.toList()
          .map((h) -> renderHealthCheck(h))
      }
      when (value.git != null) { ["git"] = value.git.toMap() }
      when (value.docker != null) { ["docker"] = value.docker.toMap() }
      when (value.build != null) { ["build"] = renderBuild(value.build) }
      when (value.privileged != null) {
        ["privileged"] = value.privileged
      }
      when (value.skip_cache != null) {
        ["skip_cache"] = value.skip_cache
      }
      when (value.run_command != null) {
        ["run_command"] = value.run_command
      }
    },
    value.extra,
  )

hidden rendered =
  Maps.withExtra(
    new Mapping<String, Any> {
      when (!services.toList().isEmpty) {
        ["services"] = services.toList().map((s) -> renderService(s))
      }
      when (!databases.toList().isEmpty) {
        ["databases"] = databases.toList().map((m) -> m.toMap())
      }
    },
    extra,
  )

output {
  value = rendered
  renderer = new YamlRenderer {}
}
