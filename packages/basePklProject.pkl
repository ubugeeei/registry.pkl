module basePklProject

amends "pkl:Project"

import "pkl:reflect"

local myModule = reflect.Module(module)
local packageHost = read?("env:PACKAGE_HOST") ?? "pkg.example.invalid"
local packageBasePathInput = read?("env:PACKAGE_BASE_PATH") ?? ""
local packageBasePath =
  if (packageBasePathInput == "") ""
  else if (packageBasePathInput.startsWith("/")) packageBasePathInput
  else "/\(packageBasePathInput)"
local packageBaseUrl =
  read?("env:PACKAGE_BASE_URL") ?? "https://\(packageHost)\(packageBasePath)"
local releaseBaseUrl = "\(packageBaseUrl)/releases"

local packageName: String =
  findRootModule(myModule)
    .relativePathTo(module)
    .last

local function findRootModule(mod: reflect.Module): Module =
  let (supermodule = mod.supermodule)
    if (supermodule == null || !supermodule.isAmend) mod.reflectee
    else findRootModule(supermodule)

const local allTests =
  import*("**/tests/**.pkl").keys.filter((it) -> !it.contains("tests/fixtures/"))

package {
  name = packageName
  version = "0.1.0"
  baseUri = "package://\(packageHost)\(packageBasePath)/\(name)"
  packageZipUrl =
    "\(releaseBaseUrl)/\(name)@\(version)/\(name)@\(version).zip"
  license = "Apache-2.0"
  authors {
    "Ubugeeei <ubugeeei@gmail.com>"
  }
  issueTracker = "https://github.com/ubugeeei/registry.pkl/issues"
  sourceCode =
    "https://github.com/ubugeeei/registry.pkl/tree/main/packages/\(name)"
  sourceCodeUrlScheme =
    "https://github.com/ubugeeei/registry.pkl/blob/main/packages/\(name)%{path}#L%{line}-L%{endLine}"
  description = myModule.docComment
  apiTests = tests
  exclude {
    "examples/**"
    "tests/**"
  }
}

tests {
  for (test in allTests) {
    when (test.split("/").first == package.name) {
      test.replaceFirst(package.name, ".")
    }
  }
}
