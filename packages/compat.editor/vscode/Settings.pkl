/// A typed authoring surface for `.vscode/settings.json`.
module compat.editor.vscode.Settings

import "@compat.core/Maps.pkl" as Maps

class EditorSettings {
  formatOnSave: Boolean? = null
  defaultFormatter: String? = null
  tabSize: Int? = null
  insertSpaces: Boolean? = null
  rulers: Listing<Int> = new Listing {}
  codeActionsOnSave: Mapping<String, String|Boolean> = new Mapping {}
}

class FilesSettings {
  insertFinalNewline: Boolean? = null
  trimTrailingWhitespace: Boolean? = null
  exclude: Mapping<String, Boolean> = new Mapping {}
  watcherExclude: Mapping<String, Boolean> = new Mapping {}
  associations: Mapping<String, String> = new Mapping {}
}

class SearchSettings {
  exclude: Mapping<String, Boolean> = new Mapping {}
  useIgnoreFiles: Boolean? = null
}

class TypeScriptSettings {
  tsdk: String? = null
  enablePromptUseWorkspaceTsdk: Boolean? = null
  preferGoToSourceDefinition: Boolean? = null
}

class JavaScriptSettings {
  suggestCompleteFunctionCalls: Boolean? = null
  quoteStyle: "auto"|"single"|"double"? = null
}

class GitSettings {
  autofetch: Boolean? = null
  enableSmartCommit: Boolean? = null
}

class WindowSettings {
  zoomLevel: Int? = null
}

editor: EditorSettings = new {}
files: FilesSettings = new {}
search: SearchSettings = new {}
typescript: TypeScriptSettings = new {}
javascript: JavaScriptSettings = new {}
git: GitSettings = new {}
window: WindowSettings = new {}
extra: Mapping<String, Any> = new Mapping {}

hidden rendered =
  Maps.withExtra(
    new Dynamic {
      when (editor.formatOnSave != null) {
        ["editor.formatOnSave"] = editor.formatOnSave
      }
      when (editor.defaultFormatter != null) {
        ["editor.defaultFormatter"] = editor.defaultFormatter
      }
      when (editor.tabSize != null) {
        ["editor.tabSize"] = editor.tabSize
      }
      when (editor.insertSpaces != null) {
        ["editor.insertSpaces"] = editor.insertSpaces
      }
      when (!editor.rulers.toList().isEmpty) {
        ["editor.rulers"] = editor.rulers.toList()
      }
      when (!editor.codeActionsOnSave.toMap().isEmpty) {
        ["editor.codeActionsOnSave"] = editor.codeActionsOnSave.toMap()
      }
      when (files.insertFinalNewline != null) {
        ["files.insertFinalNewline"] = files.insertFinalNewline
      }
      when (files.trimTrailingWhitespace != null) {
        ["files.trimTrailingWhitespace"] = files.trimTrailingWhitespace
      }
      when (!files.exclude.toMap().isEmpty) {
        ["files.exclude"] = files.exclude.toMap()
      }
      when (!files.watcherExclude.toMap().isEmpty) {
        ["files.watcherExclude"] = files.watcherExclude.toMap()
      }
      when (!files.associations.toMap().isEmpty) {
        ["files.associations"] = files.associations.toMap()
      }
      when (!search.exclude.toMap().isEmpty) {
        ["search.exclude"] = search.exclude.toMap()
      }
      when (search.useIgnoreFiles != null) {
        ["search.useIgnoreFiles"] = search.useIgnoreFiles
      }
      when (typescript.tsdk != null) {
        ["typescript.tsdk"] = typescript.tsdk
      }
      when (typescript.enablePromptUseWorkspaceTsdk != null) {
        ["typescript.enablePromptUseWorkspaceTsdk"] =
          typescript.enablePromptUseWorkspaceTsdk
      }
      when (typescript.preferGoToSourceDefinition != null) {
        ["typescript.preferGoToSourceDefinition"] =
          typescript.preferGoToSourceDefinition
      }
      when (javascript.suggestCompleteFunctionCalls != null) {
        ["javascript.suggest.completeFunctionCalls"] =
          javascript.suggestCompleteFunctionCalls
      }
      when (javascript.quoteStyle != null) {
        ["javascript.preferences.quoteStyle"] = javascript.quoteStyle
      }
      when (git.autofetch != null) {
        ["git.autofetch"] = git.autofetch
      }
      when (git.enableSmartCommit != null) {
        ["git.enableSmartCommit"] = git.enableSmartCommit
      }
      when (window.zoomLevel != null) {
        ["window.zoomLevel"] = window.zoomLevel
      }
    },
    extra,
  )

output {
  value = rendered
  renderer = new JsonRenderer {}
}
