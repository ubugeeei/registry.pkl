/// A typed authoring surface for `biome.json`.
module target.js.biome.Biome

import "@target.core/Maps.pkl" as Maps

class Formatter {
  enabled: Boolean? = null
  useEditorconfig: Boolean? = null
  formatWithErrors: Boolean? = null
  indentStyle: "space"|"tab"? = null
  indentWidth: Int? = null
  lineWidth: Int? = null
  lineEnding: "lf"|"crlf"|"cr"? = null
  attributePosition: "auto"|"multiline"? = null
  custom: Mapping<String, Any> = new Mapping {}
}

class Linter {
  enabled: Boolean? = null
  rules: Mapping<String, Any> = new Mapping {}
  custom: Mapping<String, Any> = new Mapping {}
}

class Assist {
  enabled: Boolean? = null
  actions: Mapping<String, Any> = new Mapping {}
  custom: Mapping<String, Any> = new Mapping {}
}

class Files {
  ignoreUnknown: Boolean? = null
  includes: Listing<String> = new Listing {}
  custom: Mapping<String, Any> = new Mapping {}
}

class Vcs {
  enabled: Boolean? = null
  clientKind: String? = null
  useIgnoreFile: Boolean? = null
  defaultBranch: String? = null
  custom: Mapping<String, Any> = new Mapping {}
}

class LanguageOptions {
  formatter: Mapping<String, Any> = new Mapping {}
  linter: Mapping<String, Any> = new Mapping {}
  parser: Mapping<String, Any> = new Mapping {}
  assist: Mapping<String, Any> = new Mapping {}
  custom: Mapping<String, Any> = new Mapping {}
}

`$schema`: String? = null
`extends`: Listing<String> = new Listing {}
formatter: Formatter = new {}
linter: Linter = new {}
assist: Assist = new {}
files: Files = new {}
vcs: Vcs = new {}
javascript: LanguageOptions = new {}
json: LanguageOptions = new {}
extra: Mapping<String, Any> = new Mapping {}

local function renderFormatter(value: Formatter) =
  Maps.withExtra(
    new Dynamic {
      when (value.enabled != null) { ["enabled"] = value.enabled }
      when (value.useEditorconfig != null) {
        ["useEditorconfig"] = value.useEditorconfig
      }
      when (value.formatWithErrors != null) {
        ["formatWithErrors"] = value.formatWithErrors
      }
      when (value.indentStyle != null) { ["indentStyle"] = value.indentStyle }
      when (value.indentWidth != null) { ["indentWidth"] = value.indentWidth }
      when (value.lineWidth != null) { ["lineWidth"] = value.lineWidth }
      when (value.lineEnding != null) { ["lineEnding"] = value.lineEnding }
      when (value.attributePosition != null) {
        ["attributePosition"] = value.attributePosition
      }
    },
    value.custom,
  )

local function renderLinter(value: Linter) =
  Maps.withExtra(
    new Dynamic {
      when (value.enabled != null) { ["enabled"] = value.enabled }
      when (!value.rules.toMap().isEmpty) { ["rules"] = value.rules.toMap() }
    },
    value.custom,
  )

local function renderAssist(value: Assist) =
  Maps.withExtra(
    new Dynamic {
      when (value.enabled != null) { ["enabled"] = value.enabled }
      when (!value.actions.toMap().isEmpty) {
        ["actions"] = value.actions.toMap()
      }
    },
    value.custom,
  )

local function renderFiles(value: Files) =
  Maps.withExtra(
    new Dynamic {
      when (value.ignoreUnknown != null) {
        ["ignoreUnknown"] = value.ignoreUnknown
      }
      when (!value.includes.toList().isEmpty) {
        ["includes"] = value.includes.toList()
      }
    },
    value.custom,
  )

local function renderVcs(value: Vcs) =
  Maps.withExtra(
    new Dynamic {
      when (value.enabled != null) { ["enabled"] = value.enabled }
      when (value.clientKind != null) { ["clientKind"] = value.clientKind }
      when (value.useIgnoreFile != null) {
        ["useIgnoreFile"] = value.useIgnoreFile
      }
      when (value.defaultBranch != null) {
        ["defaultBranch"] = value.defaultBranch
      }
    },
    value.custom,
  )

local function renderLanguageOptions(value: LanguageOptions) =
  Maps.withExtra(
    new Dynamic {
      when (!value.formatter.toMap().isEmpty) {
        ["formatter"] = value.formatter.toMap()
      }
      when (!value.linter.toMap().isEmpty) {
        ["linter"] = value.linter.toMap()
      }
      when (!value.parser.toMap().isEmpty) {
        ["parser"] = value.parser.toMap()
      }
      when (!value.assist.toMap().isEmpty) {
        ["assist"] = value.assist.toMap()
      }
    },
    value.custom,
  )

hidden formatterValue = renderFormatter(formatter)
hidden linterValue = renderLinter(linter)
hidden assistValue = renderAssist(assist)
hidden filesValue = renderFiles(files)
hidden vcsValue = renderVcs(vcs)
hidden javascriptValue = renderLanguageOptions(javascript)
hidden jsonValue = renderLanguageOptions(json)

hidden rendered =
  Maps.withExtra(
    new Dynamic {
      when (`$schema` != null) { ["$schema"] = `$schema` }
      when (!`extends`.toList().isEmpty) { ["extends"] = `extends`.toList() }
      when (!formatterValue.isEmpty) { ["formatter"] = formatterValue }
      when (!linterValue.isEmpty) { ["linter"] = linterValue }
      when (!assistValue.isEmpty) { ["assist"] = assistValue }
      when (!filesValue.isEmpty) { ["files"] = filesValue }
      when (!vcsValue.isEmpty) { ["vcs"] = vcsValue }
      when (!javascriptValue.isEmpty) { ["javascript"] = javascriptValue }
      when (!jsonValue.isEmpty) { ["json"] = jsonValue }
    },
    extra,
  )

output {
  value = rendered
  renderer = new JsonRenderer {}
}
