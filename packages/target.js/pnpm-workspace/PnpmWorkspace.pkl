/// A typed authoring surface for `pnpm-workspace.yaml`.
module target.js.pnpmWorkspace.PnpmWorkspace

import "@target.core/Maps.pkl" as Maps

packages: Listing<String> = new Listing {}
catalog: Mapping<String, String> = new Mapping {}
catalogs: Mapping<String, Mapping<String, String>> = new Mapping {}
onlyBuiltDependencies: Listing<String> = new Listing {}
ignoredBuiltDependencies: Listing<String> = new Listing {}
neverBuiltDependencies: Listing<String> = new Listing {}
overrides: Mapping<String, String> = new Mapping {}
packageExtensions: Mapping<String, Any> = new Mapping {}
extra: Mapping<String, Any> = new Mapping {}

hidden rendered =
  Maps.withExtra(
    new Dynamic {
      when (!packages.toList().isEmpty) { ["packages"] = packages.toList() }
      when (!catalog.toMap().isEmpty) { ["catalog"] = catalog.toMap() }
      when (!catalogs.toMap().isEmpty) {
        ["catalogs"] =
          catalogs.toMap().mapValues((_, value) -> value.toMap())
      }
      when (!onlyBuiltDependencies.toList().isEmpty) {
        ["onlyBuiltDependencies"] = onlyBuiltDependencies.toList()
      }
      when (!ignoredBuiltDependencies.toList().isEmpty) {
        ["ignoredBuiltDependencies"] = ignoredBuiltDependencies.toList()
      }
      when (!neverBuiltDependencies.toList().isEmpty) {
        ["neverBuiltDependencies"] = neverBuiltDependencies.toList()
      }
      when (!overrides.toMap().isEmpty) { ["overrides"] = overrides.toMap() }
      when (!packageExtensions.toMap().isEmpty) {
        ["packageExtensions"] = packageExtensions.toMap()
      }
    },
    extra,
  )

output {
  value = rendered
  renderer = new YamlRenderer {}
}
