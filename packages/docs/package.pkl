amends "@target.js/package-json/PackageJson.pkl"

name = "@registry/docs"
private = true
version = "0.1.0"
type = "module"

engines {
  ["node"] = ">=24"
  ["pnpm"] = ">=10"
}

scripts {
  ["dev"] = "vite"
  ["build"] = "vite build && DOCS_OUTPUT_DIR=../../dist/docs node ../../scripts/normalize-docs-search-index.mjs && DOCS_OUTPUT_DIR=../../dist/docs node ../../scripts/validate-docs-output.mjs"
  ["preview"] = "vite preview"
  ["fmt"] = "pnpm exec oxfmt --write vite.config.ts vitest.config.ts src/base.ts tests/base.test.ts tsconfig.json"
  ["lint"] = "pnpm exec oxlint --type-aware --type-check vite.config.ts vitest.config.ts src tests"
  ["check"] = "pnpm exec oxlint --type-aware --type-check vite.config.ts vitest.config.ts src tests"
  ["test"] = "pnpm exec vitest run --config vitest.config.ts"
}

devDependencies {
  ["@ox-content/napi"] = "0.16.0"
  ["@ox-content/vite-plugin"] = "0.16.0"
  ["@shikijs/langs"] = "4.0.2"
  ["@types/node"] = "25.3.5"
  ["oxfmt"] = "0.36.0"
  ["oxlint"] = "1.51.0"
  ["oxlint-tsgolint"] = "0.16.0"
  ["puppeteer"] = "24.43.1"
  ["typescript"] = "5.9.3"
  ["vite"] = "8.0.0-beta.16"
  ["vitest"] = "4.0.18"
}
