/// Tests for `target.k8s.secret.Secret` rendering.
amends "pkl:test"

import "../secret/Secret.pkl"
import "../podtemplate/PodTemplate.pkl" as Pod

local sec = (Secret) {
  metadata = new Pod.ObjectMeta {
    name = "api-secrets"
    namespace = "registry"
  }
  type = "Opaque"
  stringData {
    ["DATABASE_URL"] = "postgres://api:secret@db/registry"
    ["JWT_SIGNING_KEY"] = "redacted"
  }
  immutable = true
}

local tls = (Secret) {
  metadata = new Pod.ObjectMeta {
    name = "api-tls"
  }
  type = "kubernetes.io/tls"
  data {
    ["tls.crt"] = "LS0tLS1CRUdJTi..."
    ["tls.key"] = "LS0tLS1CRUdJTi..."
  }
}

facts {
  ["scalars pass through"] {
    sec.rendered["apiVersion"] == "v1"
    sec.rendered["kind"] == "Secret"
    sec.rendered["type"] == "Opaque"
    sec.rendered["immutable"] == true
  }
  ["stringData passes through verbatim"] {
    sec.rendered["stringData"]["DATABASE_URL"]
      == "postgres://api:secret@db/registry"
  }
  ["typed TLS secret"] {
    tls.rendered["type"] == "kubernetes.io/tls"
    tls.rendered["data"]["tls.crt"] == "LS0tLS1CRUdJTi..."
  }
}
