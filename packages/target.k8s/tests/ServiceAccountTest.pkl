/// Tests for `target.k8s.serviceaccount.ServiceAccount` rendering.
amends "pkl:test"

import "../serviceaccount/ServiceAccount.pkl"
import "../podtemplate/PodTemplate.pkl" as Pod

local sa = (ServiceAccount) {
  metadata = new Pod.ObjectMeta {
    name = "registry-api"
    namespace = "registry"
  }
  automountServiceAccountToken = false
  imagePullSecrets {
    new ServiceAccount.LocalObjectReference {
      name = "ghcr-pull"
    }
  }
}

facts {
  ["apiVersion + kind"] {
    sa.rendered["apiVersion"] == "v1"
    sa.rendered["kind"] == "ServiceAccount"
  }
  ["automountServiceAccountToken false"] {
    sa.rendered["automountServiceAccountToken"] == false
  }
  ["imagePullSecrets emits name-only objects"] {
    sa.rendered["imagePullSecrets"][0] == Map("name", "ghcr-pull")
  }
}
