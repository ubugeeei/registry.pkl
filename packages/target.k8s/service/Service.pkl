/// A typed authoring surface for a `v1.Service`.
///
/// Models the slice of the Service spec most teams configure — selector,
/// ports, type, externalTrafficPolicy. The rest falls through `extra`.
///
/// Reference: https://kubernetes.io/docs/reference/generated/kubernetes-api/v1.31/#service-v1-core
module target.k8s.service.Service

import "@target.core/Maps.pkl" as Maps
import "../podtemplate/PodTemplate.pkl" as Pod

typealias ServiceType =
  "ClusterIP"|"NodePort"|"LoadBalancer"|"ExternalName"

class ServicePort {
  name: String? = null
  protocol: ("TCP"|"UDP"|"SCTP")? = null
  appProtocol: String? = null
  port: Int
  targetPort: (String|Int)? = null
  nodePort: Int? = null
  extra: Mapping<String, Any> = new Mapping {}
}

class SessionAffinityConfig {
  clientIP: Mapping<String, Any>? = null
}

class Spec {
  selector: Mapping<String, String> = new Mapping {}
  ports: Listing<ServicePort> = new Listing {}
  type: ServiceType? = null
  clusterIP: String? = null
  clusterIPs: Listing<String> = new Listing {}
  externalIPs: Listing<String> = new Listing {}
  externalName: String? = null
  externalTrafficPolicy: ("Cluster"|"Local")? = null
  internalTrafficPolicy: ("Cluster"|"Local")? = null
  loadBalancerIP: String? = null
  loadBalancerSourceRanges: Listing<String> = new Listing {}
  loadBalancerClass: String? = null
  healthCheckNodePort: Int? = null
  publishNotReadyAddresses: Boolean? = null
  sessionAffinity: ("None"|"ClientIP")? = null
  sessionAffinityConfig: SessionAffinityConfig? = null
  ipFamilies: Listing<String> = new Listing {}
  ipFamilyPolicy: String? = null
  allocateLoadBalancerNodePorts: Boolean? = null
  trafficDistribution: String? = null
  extra: Mapping<String, Any> = new Mapping {}
}

apiVersion: String = "v1"
kind: String = "Service"
metadata: Pod.ObjectMeta
spec: Spec
extra: Mapping<String, Any> = new Mapping {}

local function renderPort(value: ServicePort) =
  Maps.withExtra(
    new Mapping<String, Any> {
      when (value.name != null) { ["name"] = value.name }
      when (value.protocol != null) { ["protocol"] = value.protocol }
      when (value.appProtocol != null) {
        ["appProtocol"] = value.appProtocol
      }
      ["port"] = value.port
      when (value.targetPort != null) {
        ["targetPort"] = value.targetPort
      }
      when (value.nodePort != null) { ["nodePort"] = value.nodePort }
    },
    value.extra,
  )

local function renderMetadata(value: Pod.ObjectMeta) =
  Maps.withExtra(
    new Mapping<String, Any> {
      when (value.name != null) { ["name"] = value.name }
      when (value.namespace != null) { ["namespace"] = value.namespace }
      when (!value.labels.toMap().isEmpty) {
        ["labels"] = value.labels.toMap()
      }
      when (!value.annotations.toMap().isEmpty) {
        ["annotations"] = value.annotations.toMap()
      }
    },
    value.extra,
  )

local function renderSpec(value: Spec) =
  Maps.withExtra(
    new Mapping<String, Any> {
      when (!value.selector.toMap().isEmpty) {
        ["selector"] = value.selector.toMap()
      }
      when (!value.ports.toList().isEmpty) {
        ["ports"] = value.ports.toList().map((p) -> renderPort(p))
      }
      when (value.type != null) { ["type"] = value.type }
      when (value.clusterIP != null) { ["clusterIP"] = value.clusterIP }
      when (!value.clusterIPs.toList().isEmpty) {
        ["clusterIPs"] = value.clusterIPs.toList()
      }
      when (!value.externalIPs.toList().isEmpty) {
        ["externalIPs"] = value.externalIPs.toList()
      }
      when (value.externalName != null) {
        ["externalName"] = value.externalName
      }
      when (value.externalTrafficPolicy != null) {
        ["externalTrafficPolicy"] = value.externalTrafficPolicy
      }
      when (value.internalTrafficPolicy != null) {
        ["internalTrafficPolicy"] = value.internalTrafficPolicy
      }
      when (value.loadBalancerIP != null) {
        ["loadBalancerIP"] = value.loadBalancerIP
      }
      when (!value.loadBalancerSourceRanges.toList().isEmpty) {
        ["loadBalancerSourceRanges"] = value.loadBalancerSourceRanges.toList()
      }
      when (value.loadBalancerClass != null) {
        ["loadBalancerClass"] = value.loadBalancerClass
      }
      when (value.healthCheckNodePort != null) {
        ["healthCheckNodePort"] = value.healthCheckNodePort
      }
      when (value.publishNotReadyAddresses != null) {
        ["publishNotReadyAddresses"] = value.publishNotReadyAddresses
      }
      when (value.sessionAffinity != null) {
        ["sessionAffinity"] = value.sessionAffinity
      }
      when (value.sessionAffinityConfig != null) {
        ["sessionAffinityConfig"] = new Mapping<String, Any> {
          when (value.sessionAffinityConfig.clientIP != null) {
            ["clientIP"] = value.sessionAffinityConfig.clientIP.toMap()
          }
        }.toMap()
      }
      when (!value.ipFamilies.toList().isEmpty) {
        ["ipFamilies"] = value.ipFamilies.toList()
      }
      when (value.ipFamilyPolicy != null) {
        ["ipFamilyPolicy"] = value.ipFamilyPolicy
      }
      when (value.allocateLoadBalancerNodePorts != null) {
        ["allocateLoadBalancerNodePorts"] = value.allocateLoadBalancerNodePorts
      }
      when (value.trafficDistribution != null) {
        ["trafficDistribution"] = value.trafficDistribution
      }
    },
    value.extra,
  )

hidden rendered =
  Maps.withExtra(
    new Mapping<String, Any> {
      ["apiVersion"] = apiVersion
      ["kind"] = kind
      ["metadata"] = renderMetadata(metadata)
      ["spec"] = renderSpec(spec)
    },
    extra,
  )

output {
  value = rendered
  renderer = new YamlRenderer {}
}
