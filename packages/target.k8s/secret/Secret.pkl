/// A typed authoring surface for `v1.Secret`.
///
/// Values under `data` must be base64-encoded by the author — Pkl does
/// not transform them. Use `stringData` for plaintext that Kubernetes
/// will base64-encode at apply time.
///
/// Reference: https://kubernetes.io/docs/reference/generated/kubernetes-api/v1.31/#secret-v1-core
module target.k8s.secret.Secret

import "@target.core/Maps.pkl" as Maps
import "../podtemplate/PodTemplate.pkl" as Pod

typealias SecretType =
  "Opaque"
  |"kubernetes.io/service-account-token"
  |"kubernetes.io/dockercfg"
  |"kubernetes.io/dockerconfigjson"
  |"kubernetes.io/basic-auth"
  |"kubernetes.io/ssh-auth"
  |"kubernetes.io/tls"
  |"bootstrap.kubernetes.io/token"

apiVersion: String = "v1"
kind: String = "Secret"
metadata: Pod.ObjectMeta
type: SecretType = "Opaque"
data: Mapping<String, String> = new Mapping {}
stringData: Mapping<String, String> = new Mapping {}
immutable: Boolean? = null
extra: Mapping<String, Any> = new Mapping {}

local function renderObjectMeta(value: Pod.ObjectMeta) =
  Maps.withExtra(
    new Mapping<String, Any> {
      when (value.name != null) { ["name"] = value.name }
      when (value.namespace != null) { ["namespace"] = value.namespace }
      when (!value.labels.toMap().isEmpty) {
        ["labels"] = value.labels.toMap()
      }
      when (!value.annotations.toMap().isEmpty) {
        ["annotations"] = value.annotations.toMap()
      }
    },
    value.extra,
  )

hidden rendered =
  Maps.withExtra(
    new Mapping<String, Any> {
      ["apiVersion"] = apiVersion
      ["kind"] = kind
      ["metadata"] = renderObjectMeta(metadata)
      ["type"] = type
      when (!data.toMap().isEmpty) {
        ["data"] = data.toMap()
      }
      when (!stringData.toMap().isEmpty) {
        ["stringData"] = stringData.toMap()
      }
      when (immutable != null) {
        ["immutable"] = immutable
      }
    },
    extra,
  )

output {
  value = rendered
  renderer = new YamlRenderer {}
}
