/// A typed authoring surface for `apps/v1.DaemonSet`.
///
/// Reference: https://kubernetes.io/docs/reference/generated/kubernetes-api/v1.31/#daemonset-v1-apps
module target.k8s.daemonset.DaemonSet

import "@target.core/Maps.pkl" as Maps
import "../podtemplate/PodTemplate.pkl" as Pod
import "../deployment/Deployment.pkl" as Dep

class UpdateStrategy {
  type: ("RollingUpdate"|"OnDelete")? = null
  rollingUpdate: Mapping<String, Any>? = null
}

class Spec {
  selector: Dep.LabelSelector
  template: Dep.Template
  updateStrategy: UpdateStrategy? = null
  minReadySeconds: Int? = null
  revisionHistoryLimit: Int? = null
  extra: Mapping<String, Any> = new Mapping {}
}

apiVersion: String = "apps/v1"
kind: String = "DaemonSet"
metadata: Pod.ObjectMeta
spec: Spec
extra: Mapping<String, Any> = new Mapping {}

local function renderObjectMeta(value: Pod.ObjectMeta) =
  Maps.withExtra(
    new Mapping<String, Any> {
      when (value.name != null) { ["name"] = value.name }
      when (value.namespace != null) { ["namespace"] = value.namespace }
      when (!value.labels.toMap().isEmpty) {
        ["labels"] = value.labels.toMap()
      }
      when (!value.annotations.toMap().isEmpty) {
        ["annotations"] = value.annotations.toMap()
      }
    },
    value.extra,
  )

local function renderSelector(value: Dep.LabelSelector) =
  new Mapping<String, Any> {
    when (!value.matchLabels.toMap().isEmpty) {
      ["matchLabels"] = value.matchLabels.toMap()
    }
    when (!value.matchExpressions.toList().isEmpty) {
      ["matchExpressions"] = value.matchExpressions.toList()
        .map((m) -> m.toMap())
    }
  }.toMap()

local function renderTemplate(value: Dep.Template) =
  new Mapping<String, Any> {
    when (value.metadata != null) {
      ["metadata"] = renderObjectMeta(value.metadata)
    }
    ["spec"] = (Pod) { spec = value.spec }.rendered["spec"]
  }.toMap()

local function renderUpdateStrategy(value: UpdateStrategy) =
  new Mapping<String, Any> {
    when (value.type != null) { ["type"] = value.type }
    when (value.rollingUpdate != null) {
      ["rollingUpdate"] = value.rollingUpdate.toMap()
    }
  }.toMap()

local function renderSpec(value: Spec) =
  Maps.withExtra(
    new Mapping<String, Any> {
      ["selector"] = renderSelector(value.selector)
      ["template"] = renderTemplate(value.template)
      when (value.updateStrategy != null) {
        ["updateStrategy"] = renderUpdateStrategy(value.updateStrategy)
      }
      when (value.minReadySeconds != null) {
        ["minReadySeconds"] = value.minReadySeconds
      }
      when (value.revisionHistoryLimit != null) {
        ["revisionHistoryLimit"] = value.revisionHistoryLimit
      }
    },
    value.extra,
  )

hidden rendered =
  Maps.withExtra(
    new Mapping<String, Any> {
      ["apiVersion"] = apiVersion
      ["kind"] = kind
      ["metadata"] = renderObjectMeta(metadata)
      ["spec"] = renderSpec(spec)
    },
    extra,
  )

output {
  value = rendered
  renderer = new YamlRenderer {}
}
