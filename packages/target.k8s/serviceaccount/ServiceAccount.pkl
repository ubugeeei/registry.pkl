/// A typed authoring surface for `v1.ServiceAccount`.
///
/// Reference: https://kubernetes.io/docs/reference/generated/kubernetes-api/v1.31/#serviceaccount-v1-core
module target.k8s.serviceaccount.ServiceAccount

import "@target.core/Maps.pkl" as Maps
import "../podtemplate/PodTemplate.pkl" as Pod

class LocalObjectReference {
  name: String
}

apiVersion: String = "v1"
kind: String = "ServiceAccount"
metadata: Pod.ObjectMeta
automountServiceAccountToken: Boolean? = null
imagePullSecrets: Listing<LocalObjectReference> = new Listing {}
secrets: Listing<Mapping<String, Any>> = new Listing {}
extra: Mapping<String, Any> = new Mapping {}

local function renderObjectMeta(value: Pod.ObjectMeta) =
  Maps.withExtra(
    new Mapping<String, Any> {
      when (value.name != null) { ["name"] = value.name }
      when (value.namespace != null) { ["namespace"] = value.namespace }
      when (!value.labels.toMap().isEmpty) {
        ["labels"] = value.labels.toMap()
      }
      when (!value.annotations.toMap().isEmpty) {
        ["annotations"] = value.annotations.toMap()
      }
    },
    value.extra,
  )

hidden rendered =
  Maps.withExtra(
    new Mapping<String, Any> {
      ["apiVersion"] = apiVersion
      ["kind"] = kind
      ["metadata"] = renderObjectMeta(metadata)
      when (automountServiceAccountToken != null) {
        ["automountServiceAccountToken"] = automountServiceAccountToken
      }
      when (!imagePullSecrets.toList().isEmpty) {
        ["imagePullSecrets"] = imagePullSecrets.toList()
          .map((r) -> new Mapping<String, Any> { ["name"] = r.name }.toMap())
      }
      when (!secrets.toList().isEmpty) {
        ["secrets"] = secrets.toList().map((m) -> m.toMap())
      }
    },
    extra,
  )

output {
  value = rendered
  renderer = new YamlRenderer {}
}
