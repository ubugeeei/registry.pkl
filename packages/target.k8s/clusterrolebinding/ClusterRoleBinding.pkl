/// A typed authoring surface for `rbac.authorization.k8s.io/v1.ClusterRoleBinding`.
///
/// Cluster-scoped equivalent of RoleBinding; reuses RoleBinding's
/// Subject / RoleRef classes.
///
/// Reference: https://kubernetes.io/docs/reference/generated/kubernetes-api/v1.31/#clusterrolebinding-v1-rbac-authorization-k8s-io
module target.k8s.clusterrolebinding.ClusterRoleBinding

import "@target.core/Maps.pkl" as Maps
import "../podtemplate/PodTemplate.pkl" as Pod
import "../rolebinding/RoleBinding.pkl" as Rb

apiVersion: String = "rbac.authorization.k8s.io/v1"
kind: String = "ClusterRoleBinding"
metadata: Pod.ObjectMeta
subjects: Listing<Rb.Subject> = new Listing {}
roleRef: Rb.RoleRef
extra: Mapping<String, Any> = new Mapping {}

local function renderObjectMeta(value: Pod.ObjectMeta) =
  Maps.withExtra(
    new Mapping<String, Any> {
      when (value.name != null) { ["name"] = value.name }
      when (value.namespace != null) { ["namespace"] = value.namespace }
      when (!value.labels.toMap().isEmpty) {
        ["labels"] = value.labels.toMap()
      }
      when (!value.annotations.toMap().isEmpty) {
        ["annotations"] = value.annotations.toMap()
      }
    },
    value.extra,
  )

local function renderSubject(value: Rb.Subject) =
  new Mapping<String, Any> {
    ["kind"] = value.kind
    ["name"] = value.name
    when (value.namespace != null) { ["namespace"] = value.namespace }
    when (value.apiGroup != null) { ["apiGroup"] = value.apiGroup }
  }.toMap()

local function renderRoleRef(value: Rb.RoleRef) =
  new Mapping<String, Any> {
    ["apiGroup"] = value.apiGroup
    ["kind"] = value.kind
    ["name"] = value.name
  }.toMap()

hidden rendered =
  Maps.withExtra(
    new Mapping<String, Any> {
      ["apiVersion"] = apiVersion
      ["kind"] = kind
      ["metadata"] = renderObjectMeta(metadata)
      when (!subjects.toList().isEmpty) {
        ["subjects"] = subjects.toList().map((s) -> renderSubject(s))
      }
      ["roleRef"] = renderRoleRef(roleRef)
    },
    extra,
  )

output {
  value = rendered
  renderer = new YamlRenderer {}
}
