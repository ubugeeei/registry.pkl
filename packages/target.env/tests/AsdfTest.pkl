/// Tests for `target.env.asdf.Asdf` rendering.
amends "pkl:test"

import "../asdf/Asdf.pkl"

local config = (Asdf) {
  tools {
    ["nodejs"] = "20.10.0"
    ["python"] = new Listing<String> { "3.12.1"; "3.11.7" }
    ["rust"] = "1.78.0"
  }
  comments {
    "Pinned per release ticket REG-42"
  }
}

facts {
  ["single version emits as-is"] {
    config.rendered.contains("nodejs 20.10.0")
  }
  ["listing flattens to space-separated fallback chain"] {
    config.rendered.contains("python 3.12.1 3.11.7")
  }
  ["comment lines render with leading #"] {
    config.rendered.startsWith("# Pinned per release ticket REG-42")
  }
  ["trailing newline present"] {
    config.rendered.endsWith("\n")
  }
}
