/// A typed authoring surface for Buildkite's `.buildkite/pipeline.yml`.
///
/// Buildkite pipelines are a YAML document with `steps:` listing
/// command/wait/block/trigger/group entries. This module covers all
/// five step kinds with a tagged union; the rest of the fields fall
/// through to `extra`.
///
/// Reference: https://buildkite.com/docs/pipelines/defining-steps
module target.ci.buildkite.Buildkite

import "@target.core/Maps.pkl" as Maps

class Retry {
  automatic: (Boolean|Listing<Mapping<String, Any>>)? = null
  manual: (Boolean|Mapping<String, Any>)? = null
  extra: Mapping<String, Any> = new Mapping {}
}

typealias AgentTags = Mapping<String, String|Listing<String>>

class CommandStep {
  kind: "command" = "command"
  label: String? = null
  key: String? = null
  command: (String|Listing<String>)? = null
  commands: Listing<String> = new Listing {}
  env: Mapping<String, String> = new Mapping {}
  agents: AgentTags = new Mapping {}
  artifactPaths: Listing<String> = new Listing {}
  branches: (String|Listing<String>)? = null
  `if`: String? = null
  dependsOn: Listing<String|Mapping<String, Any>> = new Listing {}
  allow_dependency_failure: Boolean? = null
  retry: Retry? = null
  timeout_in_minutes: Int? = null
  parallelism: Int? = null
  concurrency: Int? = null
  concurrency_group: String? = null
  concurrency_method: ("ordered"|"eager")? = null
  plugins: Listing<Mapping<String, Mapping<String, Any>>> = new Listing {}
  matrix: (Listing<Mapping<String, Any>>|Mapping<String, Any>)? = null
  soft_fail: (Boolean|Listing<Mapping<String, Int>>)? = null
  skip: (Boolean|String)? = null
  cancel_on_build_failing: Boolean? = null
  notify: Listing<Mapping<String, Any>> = new Listing {}
  signature: Mapping<String, Any>? = null
  priority: Int? = null
  extra: Mapping<String, Any> = new Mapping {}
}

class WaitStep {
  kind: "wait" = "wait"
  wait: String? = null
  continue_on_failure: Boolean? = null
  `if`: String? = null
  allow_dependency_failure: Boolean? = null
  extra: Mapping<String, Any> = new Mapping {}
}

class BlockStep {
  kind: "block" = "block"
  block: String
  prompt: String? = null
  blocked_state: ("passed"|"failed"|"running")? = null
  fields: Listing<Mapping<String, Any>> = new Listing {}
  branches: (String|Listing<String>)? = null
  `if`: String? = null
  depends_on: Listing<String> = new Listing {}
  key: String? = null
  allow_dependency_failure: Boolean? = null
  extra: Mapping<String, Any> = new Mapping {}
}

class InputStep {
  kind: "input" = "input"
  input: String
  prompt: String? = null
  fields: Listing<Mapping<String, Any>> = new Listing {}
  branches: (String|Listing<String>)? = null
  `if`: String? = null
  depends_on: Listing<String> = new Listing {}
  key: String? = null
  allow_dependency_failure: Boolean? = null
  extra: Mapping<String, Any> = new Mapping {}
}

class TriggerStep {
  kind: "trigger" = "trigger"
  trigger: String
  label: String? = null
  build: Mapping<String, Any>? = null
  async: Boolean? = null
  branches: (String|Listing<String>)? = null
  `if`: String? = null
  depends_on: Listing<String> = new Listing {}
  key: String? = null
  allow_dependency_failure: Boolean? = null
  soft_fail: Boolean? = null
  skip: (Boolean|String)? = null
  extra: Mapping<String, Any> = new Mapping {}
}

class GroupStep {
  kind: "group" = "group"
  group: String? = null
  key: String? = null
  /// Nested steps. Typed loosely (CommandStep|WaitStep|BlockStep|InputStep|
  /// TriggerStep) to avoid cyclic typealiases — groups cannot nest groups.
  steps: Listing<CommandStep|WaitStep|BlockStep|InputStep|TriggerStep>
  depends_on: Listing<String> = new Listing {}
  `if`: String? = null
  allow_dependency_failure: Boolean? = null
  notify: Listing<Mapping<String, Any>> = new Listing {}
  extra: Mapping<String, Any> = new Mapping {}
}

typealias Step =
  CommandStep|WaitStep|BlockStep|InputStep|TriggerStep|GroupStep

env: Mapping<String, String> = new Mapping {}
agents: AgentTags = new Mapping {}
steps: Listing<Step> = new Listing {}
notify: Listing<Mapping<String, Any>> = new Listing {}
extra: Mapping<String, Any> = new Mapping {}

local function renderAgents(value: AgentTags) =
  value.toMap().mapValues((_, v) ->
    if (v is Listing) v.toList() else v
  )

local function renderRetry(value: Retry) =
  Maps.withExtra(
    new Mapping<String, Any> {
      when (value.automatic != null) {
        ["automatic"] =
          if (value.automatic is Listing) value.automatic.toList().map((m) -> m.toMap())
          else value.automatic
      }
      when (value.manual != null) {
        ["manual"] =
          if (value.manual is Mapping) value.manual.toMap()
          else value.manual
      }
    },
    value.extra,
  )

local function renderDependency(value: String|Mapping<String, Any>) =
  if (value is Mapping) value.toMap() else value

local function renderCommand(value: CommandStep) =
  Maps.withExtra(
    new Mapping<String, Any> {
      when (value.label != null) { ["label"] = value.label }
      when (value.key != null) { ["key"] = value.key }
      when (value.command != null) {
        ["command"] = if (value.command is Listing) value.command.toList() else value.command
      }
      when (!value.commands.toList().isEmpty) {
        ["commands"] = value.commands.toList()
      }
      when (!value.env.toMap().isEmpty) {
        ["env"] = value.env.toMap()
      }
      when (!value.agents.toMap().isEmpty) {
        ["agents"] = renderAgents(value.agents)
      }
      when (!value.artifactPaths.toList().isEmpty) {
        ["artifact_paths"] = value.artifactPaths.toList()
      }
      when (value.branches != null) {
        ["branches"] = if (value.branches is Listing) value.branches.toList() else value.branches
      }
      when (value.`if` != null) { ["if"] = value.`if` }
      when (!value.dependsOn.toList().isEmpty) {
        ["depends_on"] = value.dependsOn.toList().map((d) -> renderDependency(d))
      }
      when (value.allow_dependency_failure != null) {
        ["allow_dependency_failure"] = value.allow_dependency_failure
      }
      when (value.retry != null) { ["retry"] = renderRetry(value.retry) }
      when (value.timeout_in_minutes != null) {
        ["timeout_in_minutes"] = value.timeout_in_minutes
      }
      when (value.parallelism != null) {
        ["parallelism"] = value.parallelism
      }
      when (value.concurrency != null) {
        ["concurrency"] = value.concurrency
      }
      when (value.concurrency_group != null) {
        ["concurrency_group"] = value.concurrency_group
      }
      when (value.concurrency_method != null) {
        ["concurrency_method"] = value.concurrency_method
      }
      when (!value.plugins.toList().isEmpty) {
        ["plugins"] = value.plugins.toList().map((p) -> p.toMap()
          .mapValues((_, v) -> v.toMap())
        )
      }
      when (value.matrix != null) {
        ["matrix"] =
          if (value.matrix is Listing) value.matrix.toList().map((m) -> m.toMap())
          else value.matrix.toMap()
      }
      when (value.soft_fail != null) {
        ["soft_fail"] =
          if (value.soft_fail is Listing) value.soft_fail.toList().map((m) -> m.toMap())
          else value.soft_fail
      }
      when (value.skip != null) { ["skip"] = value.skip }
      when (value.cancel_on_build_failing != null) {
        ["cancel_on_build_failing"] = value.cancel_on_build_failing
      }
      when (!value.notify.toList().isEmpty) {
        ["notify"] = value.notify.toList().map((n) -> n.toMap())
      }
      when (value.signature != null) {
        ["signature"] = value.signature.toMap()
      }
      when (value.priority != null) {
        ["priority"] = value.priority
      }
    },
    value.extra,
  )

local function renderWait(value: WaitStep) =
  Maps.withExtra(
    new Mapping<String, Any> {
      ["wait"] = value.wait
      when (value.continue_on_failure != null) {
        ["continue_on_failure"] = value.continue_on_failure
      }
      when (value.`if` != null) { ["if"] = value.`if` }
      when (value.allow_dependency_failure != null) {
        ["allow_dependency_failure"] = value.allow_dependency_failure
      }
    },
    value.extra,
  )

local function renderBlock(value: BlockStep) =
  Maps.withExtra(
    new Mapping<String, Any> {
      ["block"] = value.block
      when (value.prompt != null) { ["prompt"] = value.prompt }
      when (value.blocked_state != null) {
        ["blocked_state"] = value.blocked_state
      }
      when (!value.fields.toList().isEmpty) {
        ["fields"] = value.fields.toList().map((f) -> f.toMap())
      }
      when (value.branches != null) {
        ["branches"] = if (value.branches is Listing) value.branches.toList() else value.branches
      }
      when (value.`if` != null) { ["if"] = value.`if` }
      when (!value.depends_on.toList().isEmpty) {
        ["depends_on"] = value.depends_on.toList()
      }
      when (value.key != null) { ["key"] = value.key }
      when (value.allow_dependency_failure != null) {
        ["allow_dependency_failure"] = value.allow_dependency_failure
      }
    },
    value.extra,
  )

local function renderInput(value: InputStep) =
  Maps.withExtra(
    new Mapping<String, Any> {
      ["input"] = value.input
      when (value.prompt != null) { ["prompt"] = value.prompt }
      when (!value.fields.toList().isEmpty) {
        ["fields"] = value.fields.toList().map((f) -> f.toMap())
      }
      when (value.branches != null) {
        ["branches"] = if (value.branches is Listing) value.branches.toList() else value.branches
      }
      when (value.`if` != null) { ["if"] = value.`if` }
      when (!value.depends_on.toList().isEmpty) {
        ["depends_on"] = value.depends_on.toList()
      }
      when (value.key != null) { ["key"] = value.key }
      when (value.allow_dependency_failure != null) {
        ["allow_dependency_failure"] = value.allow_dependency_failure
      }
    },
    value.extra,
  )

local function renderTrigger(value: TriggerStep) =
  Maps.withExtra(
    new Mapping<String, Any> {
      ["trigger"] = value.trigger
      when (value.label != null) { ["label"] = value.label }
      when (value.build != null) { ["build"] = value.build.toMap() }
      when (value.async != null) { ["async"] = value.async }
      when (value.branches != null) {
        ["branches"] = if (value.branches is Listing) value.branches.toList() else value.branches
      }
      when (value.`if` != null) { ["if"] = value.`if` }
      when (!value.depends_on.toList().isEmpty) {
        ["depends_on"] = value.depends_on.toList()
      }
      when (value.key != null) { ["key"] = value.key }
      when (value.allow_dependency_failure != null) {
        ["allow_dependency_failure"] = value.allow_dependency_failure
      }
      when (value.soft_fail != null) {
        ["soft_fail"] = value.soft_fail
      }
      when (value.skip != null) { ["skip"] = value.skip }
    },
    value.extra,
  )

local function renderStep(value: Step): Any =
  if (value is CommandStep) renderCommand(value)
  else if (value is WaitStep) renderWait(value)
  else if (value is BlockStep) renderBlock(value)
  else if (value is InputStep) renderInput(value)
  else if (value is TriggerStep) renderTrigger(value)
  else if (value is GroupStep) renderGroup(value)
  else value

local function renderGroup(value: GroupStep) =
  Maps.withExtra(
    new Mapping<String, Any> {
      when (value.group != null) { ["group"] = value.group }
      when (value.key != null) { ["key"] = value.key }
      ["steps"] = value.steps.toList().map((s) -> renderStep(s))
      when (!value.depends_on.toList().isEmpty) {
        ["depends_on"] = value.depends_on.toList()
      }
      when (value.`if` != null) { ["if"] = value.`if` }
      when (value.allow_dependency_failure != null) {
        ["allow_dependency_failure"] = value.allow_dependency_failure
      }
      when (!value.notify.toList().isEmpty) {
        ["notify"] = value.notify.toList().map((n) -> n.toMap())
      }
    },
    value.extra,
  )

hidden rendered =
  Maps.withExtra(
    new Mapping<String, Any> {
      when (!env.toMap().isEmpty) { ["env"] = env.toMap() }
      when (!agents.toMap().isEmpty) {
        ["agents"] = renderAgents(agents)
      }
      ["steps"] = steps.toList().map((s) -> renderStep(s))
      when (!notify.toList().isEmpty) {
        ["notify"] = notify.toList().map((n) -> n.toMap())
      }
    },
    extra,
  )

output {
  value = rendered
  renderer = new YamlRenderer {}
}
