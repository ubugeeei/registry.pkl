/// Tests for `target.ci.gitlab.GitLabCi` rendering at fat-surface depth.
amends "pkl:test"

import "../gitlab/GitLabCi.pkl"

local pipeline = (GitLabCi) {
  stages {
    "lint"
    "test"
    "build"
  }
  variables {
    ["FOO"] = "bar"
  }
  default = new GitLabCi.Defaults {
    image = new GitLabCi.Image {
      name = "node:24"
      pullPolicy = "if-not-present"
    }
    cache = new GitLabCi.Cache {
      key = new GitLabCi.CacheKeyFiles {
        files {
          "pnpm-lock.yaml"
        }
        prefix = "deps"
      }
      paths {
        ".pnpm-store"
      }
      policy = "pull-push"
    }
    interruptible = true
  }
  workflow = new GitLabCi.Workflow {
    rules {
      new GitLabCi.WorkflowRule {
        `if` = "$CI_PIPELINE_SOURCE == 'merge_request_event'"
      }
    }
  }
  jobs {
    ["test"] = new GitLabCi.Job {
      stage = "test"
      script = "pnpm test"
      retry = new GitLabCi.Retry {
        max = 2
        `when` = "runner_system_failure"
      }
      artifacts = new GitLabCi.Artifacts {
        paths {
          "junit.xml"
        }
        expireIn = "30 days"
      }
    }
    ["release"] = new GitLabCi.Job {
      stage = "build"
      script = "echo release"
      rules {
        new GitLabCi.Rule {
          `if` = "$CI_COMMIT_TAG"
        }
      }
      environment = new GitLabCi.Environment {
        name = "production"
        deploymentTier = "production"
      }
    }
  }
}

facts {
  ["stages list rendered"] {
    pipeline.rendered["stages"] == List("lint", "test", "build")
  }
  ["default image and pull policy"] {
    pipeline.rendered["default"]["image"]["name"] == "node:24"
    pipeline.rendered["default"]["image"]["pull_policy"] == "if-not-present"
  }
  ["default cache key object expanded"] {
    local cache = pipeline.rendered["default"]["cache"]
    cache["key"]["files"] == List("pnpm-lock.yaml")
    cache["key"]["prefix"] == "deps"
    cache["paths"] == List(".pnpm-store")
    cache["policy"] == "pull-push"
  }
  ["workflow rules emit"] {
    pipeline.rendered["workflow"]["rules"][0]["if"] ==
      "$CI_PIPELINE_SOURCE == 'merge_request_event'"
  }
  ["job retry table renders max and when"] {
    local job = pipeline.rendered["test"]
    job["retry"]["max"] == 2
    job["retry"]["when"] == "runner_system_failure"
  }
  ["artifacts expire_in renames"] {
    pipeline.rendered["test"]["artifacts"]["expire_in"] == "30 days"
  }
  ["release job rules and environment"] {
    local rel = pipeline.rendered["release"]
    rel["rules"][0]["if"] == "$CI_COMMIT_TAG"
    rel["environment"]["name"] == "production"
    rel["environment"]["deployment_tier"] == "production"
  }
}
