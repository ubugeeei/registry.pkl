examples {
  ["Cargo.toml"] {
    """
    [package]
    name = "registry-pkl-cli"
    version = "0.2.0"
    edition = "2024"
    description = "Registry tooling for Pkl config packages"
    rust-version = "1.86"
    authors = [ "Ubugeeei <ubugeeei@gmail.com>" ]
    license = "Apache-2.0"
    homepage = "https://ubugeeei.dev/registry.pkl"
    documentation = "https://ubugeeei.github.io/registry.pkl/"
    repository = "https://github.com/ubugeeei/registry.pkl"
    readme = "README.md"
    default-run = "registry-pkl"
    keywords = [ "pkl", "config" ]
    categories = [ "command-line-utilities" ]
    include = [ "src/**", "README.md", "LICENSE" ]
    
    [package.metadata.dist]
    install = "cargo install registry-pkl-cli"
    
    [workspace]
    members = [ "crates/*" ]
    resolver = "2"
    
    [workspace.package]
    edition = "2024"
    license = "Apache-2.0"
    repository = "https://github.com/ubugeeei/registry.pkl"
    
    [workspace.dependencies]
    anyhow = "1.0.100"
    
    [workspace.dependencies.serde]
    version = "1.0.228"
    features = [ "derive" ]
    
    [workspace.lints.rust]
    unsafe_code = "forbid"
    
    [dependencies]
    anyhow = "1.0.100"
    
    [dependencies.clap]
    version = "4.5.32"
    features = [ "derive", "env" ]
    
    [dev-dependencies]
    insta = "1.43.1"
    
    [build-dependencies.vergen]
    version = "9.0.5"
    default-features = false
    features = [ "build" ]
    
    [target."cfg(unix)".dependencies]
    tikv-jemallocator = "0.6.0"
    
    [features]
    default = [ "cli" ]
    cli = [ "dep:clap" ]
    
    [profile.release]
    lto = "thin"
    codegen-units = 1
    panic = "abort"
    strip = true
    
    [lints.rust]
    unsafe_code = "forbid"
    
    [patch.crates-io.serde]
    git = "https://github.com/serde-rs/serde"
    rev = "v1.0.228"
    
    [lib]
    path = "src/lib.rs"
    doctest = true
    
    [[bin]]
    name = "registry-pkl"
    path = "src/main.rs"
    required-features = [ "cli" ]
    """
  }
}
