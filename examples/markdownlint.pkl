amends "@target.lint/markdownlint/Markdownlint.pkl"

`$schema` = "https://raw.githubusercontent.com/DavidAnson/markdownlint/main/schema/markdownlint-config-schema.json"
default = true

lineLength = 100
headingStyle = "atx"
ulStyle = "dash"
codeBlockStyle = "fenced"
codeFenceStyle = "backtick"

rules {
  ["MD024"] = new Mapping<String, Any> {
    ["siblings_only"] = true
  }
  ["MD041"] = false
}

ignore {
  "CHANGELOG.md"
  "**/node_modules/**"
}
