amends "@target.editor/zed/Settings.pkl"

theme = new Mapping<String, String> {
  ["mode"] = "system"
  ["light"] = "One Light"
  ["dark"] = "One Dark"
}

buffer_font_family = "Iosevka"
buffer_font_size = 14
ui_font_family = "Inter"
ui_font_size = 14
vim_mode = true
relative_line_numbers = true
show_whitespaces = "selection"
format_on_save = "on"
ensure_final_newline_on_save = true
remove_trailing_whitespace_on_save = true

languages {
  ["Rust"] = new LanguageSettings {
    tab_size = 4
    formatter = "language_server"
    enable_language_server = true
    language_servers {
      "rust-analyzer"
    }
  }
  ["TypeScript"] = new LanguageSettings {
    tab_size = 2
    format_on_save = "on"
    preferred_line_length = 100
  }
  ["Markdown"] = new LanguageSettings {
    soft_wrap = "preferred_line_length"
    preferred_line_length = 80
    format_on_save = "off"
  }
}

assistant = new Assistant {
  version = "2"
  enabled = true
  button = true
  default_open_ai_model = "gpt-4o"
}

file_scan_exclusions {
  "**/.git"
  "**/node_modules"
  "**/.cache"
  "**/target"
  "**/dist"
}
