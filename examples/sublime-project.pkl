amends "@target.editor/sublime/Project.pkl"

folders {
  new Folder {
    path = "."
    follow_symlinks = true
    folder_exclude_patterns {
      "node_modules"
      "dist"
      "target"
      ".cache"
      ".pkl-cache"
    }
    file_exclude_patterns {
      "*.pyc"
      "*.pyo"
      "*.log"
    }
    binary_file_patterns {
      "*.zip"
      "*.tar.gz"
    }
  }
  new Folder {
    path = "docs"
    name = "Docs"
  }
}

settings {
  ["tab_size"] = 2
  ["translate_tabs_to_spaces"] = true
  ["ensure_newline_at_eof_on_save"] = true
  ["trim_trailing_white_space_on_save"] = true
  ["rulers"] = new Listing<Int> { 80; 100 }
}

build_systems {
  new BuildSystem {
    name = "Test"
    shell_cmd = "pnpm test"
    working_dir = "$project_path"
    file_regex = "([^:]+):([0-9]+):([0-9]+)"
    selector = "source.ts, source.tsx, source.js"
    variants {
      new Mapping<String, Any> {
        ["name"] = "Watch"
        ["shell_cmd"] = "pnpm test --watch"
      }
    }
  }
  new BuildSystem {
    name = "Lint"
    shell_cmd = "pnpm lint"
    working_dir = "$project_path"
  }
}
