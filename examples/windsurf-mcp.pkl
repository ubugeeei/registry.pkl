amends "@target.agent/windsurf/McpConfig.pkl"

import "@target.agent/mcp/Core.pkl" as Mcp

mcpServers {
  ["github"] =
    new Mcp.StdioServer {
      command = "npx"
      args {
        "-y"
        "@modelcontextprotocol/server-github"
      }
      env {
        ["GITHUB_PERSONAL_ACCESS_TOKEN"] = "${env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    }
  ["remoteDocs"] =
    new Mcp.RemoteServer {
      url = "https://api.example.com/mcp"
      headers {
        ["Authorization"] = "Bearer ${env:REMOTE_DOCS_TOKEN}"
      }
    }
}
