amends "@target.k8s/secret/Secret.pkl"

import "@target.k8s/podtemplate/PodTemplate.pkl" as Pod

metadata = new Pod.ObjectMeta {
  name = "registry-api-secrets"
  namespace = "registry"
  labels { ["app"] = "registry-api" }
}

type = "Opaque"

// Plaintext values; Kubernetes base64-encodes these at apply time.
stringData {
  ["DATABASE_URL"] = "postgres://api:CHANGE_ME@postgres:5432/registry"
  ["JWT_SIGNING_KEY"] = "CHANGE_ME"
  ["S3_ACCESS_KEY"] = "CHANGE_ME"
  ["S3_SECRET_KEY"] = "CHANGE_ME"
}

immutable = false
