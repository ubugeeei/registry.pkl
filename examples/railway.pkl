amends "@target.deploy/railway/Railway.pkl"

`$schema` = "https://railway.com/railway.schema.json"

build = new Build {
  builder = "DOCKERFILE"
  dockerfilePath = "Dockerfile"
  watchPatterns {
    "src/**"
    "Cargo.toml"
    "Cargo.lock"
  }
}

deploy = new Deploy {
  startCommand = "./target/release/registry-api"
  numReplicas = 2
  region = new Listing<String> { "us-east-1"; "eu-west-1" }
  healthcheckPath = "/healthz"
  healthcheckTimeout = 30
  healthcheckInterval = 30
  restartPolicyType = "ON_FAILURE"
  restartPolicyMaxRetries = 5
  drainingSeconds = 30
  overlapSeconds = 5
  sleepApplication = false
  runtime = "V2"
}

environments {
  ["staging"] = new EnvironmentConfig {
    deploy = new Deploy {
      numReplicas = 1
      sleepApplication = true
    }
  }
  ["production"] = new EnvironmentConfig {
    deploy = new Deploy {
      numReplicas = 5
      restartPolicyType = "ALWAYS"
    }
  }
}
