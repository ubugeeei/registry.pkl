amends "@target.rust/cargo-deny/CargoDeny.pkl"

graph = new Graph {
  targets {
    "x86_64-unknown-linux-gnu"
    "x86_64-pc-windows-msvc"
    "aarch64-apple-darwin"
  }
  all_features = true
}

advisories = new Advisories {
  vulnerability = "deny"
  unmaintained = "workspace"
  yanked = "warn"
  notice = "warn"
  ignore {
    "RUSTSEC-2020-0071"
  }
}

licenses = new Licenses {
  allow {
    "MIT"
    "Apache-2.0"
    "Apache-2.0 WITH LLVM-exception"
    "BSD-2-Clause"
    "BSD-3-Clause"
    "ISC"
    "Unicode-DFS-2016"
    "CC0-1.0"
    "Zlib"
  }
  deny {
    "GPL-3.0"
    "AGPL-3.0"
  }
  confidence_threshold = 0.9
  copyleft = "deny"
  default = "deny"
}

bans = new Bans {
  multiple_versions = "warn"
  wildcards = "deny"
  highlight = "all"
}

sources = new Sources {
  unknown_registry = "deny"
  unknown_git = "deny"
  allow_registry {
    "https://github.com/rust-lang/crates.io-index"
  }
  allow_org {
    ["github"] = new Listing<String> { "ubugeeei" }
  }
}
