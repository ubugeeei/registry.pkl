amends "@target.js/stylelint/Stylelint.pkl"

`extends` = new Listing<String> {
  "stylelint-config-standard"
  "stylelint-config-recess-order"
}

plugins {
  "stylelint-order"
  "stylelint-no-unsupported-browser-features"
}

defaultSeverity = "error"
reportNeedlessDisables = true

rules {
  ["color-hex-length"] = "short"
  ["max-nesting-depth"] = 4
  ["no-descending-specificity"] = null
  ["selector-class-pattern"] = new Listing<Any> {
    "^[a-z][a-zA-Z0-9]+$"
    new Mapping<String, Any> {
      ["message"] = "Use camelCase class names"
    }.toMap()
  }
  ["plugin/no-unsupported-browser-features"] = new Listing<Any> {
    true
    new Mapping<String, Any> {
      ["severity"] = "warning"
    }.toMap()
  }
}

ignoreFiles {
  "node_modules/**"
  "dist/**"
  "**/*.min.css"
}

overrides {
  new OverrideEntry {
    files = new Listing<String> { "**/*.scss" }
    customSyntax = "postcss-scss"
    rules {
      ["scss/at-rule-no-unknown"] = true
      ["scss/dollar-variable-pattern"] = "^[a-z][a-zA-Z0-9]+$"
    }
  }
}
