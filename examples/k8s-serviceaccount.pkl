amends "@target.k8s/serviceaccount/ServiceAccount.pkl"

import "@target.k8s/podtemplate/PodTemplate.pkl" as Pod

metadata = new Pod.ObjectMeta {
  name = "registry-api"
  namespace = "registry"
  labels { ["app"] = "registry-api" }
  annotations {
    ["eks.amazonaws.com/role-arn"] = "arn:aws:iam::123456789012:role/registry-api"
  }
}

automountServiceAccountToken = true

imagePullSecrets {
  new LocalObjectReference {
    name = "ghcr-pull"
  }
}
