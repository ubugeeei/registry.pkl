amends "@target.js/vitest/Vitest.pkl"

environment = "node"
globals = true
testTimeout = 10000
include {
  "**/*.{test,spec}.?(c|m)[jt]s?(x)"
}
exclude {
  "**/node_modules/**"
  "**/dist/**"
}

setupFiles = new Listing<String> {
  "./tests/setup.ts"
}

coverage = new Coverage {
  provider = "v8"
  reporter = new Listing<String> {
    "text"
    "html"
    "json-summary"
  }
  enabled = true
  reportOnFailure = true
  thresholds {
    ["statements"] = 80
    ["branches"] = 75
    ["functions"] = 80
    ["lines"] = 80
  }
}
