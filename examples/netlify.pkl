amends "@target.deploy/netlify/Netlify.pkl"

build = new BuildSection {
  command = "pnpm build"
  publish = "dist"
  edgeFunctions = "netlify/edge-functions"
  environment {
    ["NODE_VERSION"] = "24"
    ["PNPM_VERSION"] = "10.31.0"
  }
}

context {
  ["production"] = new Context {
    command = "pnpm build:prod"
    environment {
      ["MODE"] = "production"
    }
  }
  ["deploy-preview"] = new Context {
    command = "pnpm build:preview"
  }
}

redirects {
  new Redirect {
    from = "/api/*"
    to = "https://api.example.invalid/:splat"
    status = 200
    force = true
  }
}

headers {
  new HeaderBlock {
    `for` = "/*"
    values {
      ["X-Frame-Options"] = "DENY"
      ["Strict-Transport-Security"] = "max-age=63072000; includeSubDomains; preload"
    }
  }
}

edgeFunctions {
  new EdgeFunction {
    path = "/api/edge/*"
    `function` = "edge-handler"
  }
}

plugins {
  new Plugin {
    package = "@netlify/plugin-lighthouse"
  }
}
