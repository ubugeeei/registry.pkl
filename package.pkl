amends "@target.js/package-json/PackageJson.pkl"

name = "registry-pkl"
private = true
version = "0.1.0"
packageManager = "pnpm@10.31.0"

scripts {
  ["gen"] = "pkl eval -m . root-files.pkl"
  ["dev"] = "pnpm --filter @registry/docs dev"
  ["build"] = "pnpm --filter @registry/docs build"
  ["preview"] = "pnpm --filter @registry/docs preview"
  ["package:artifacts"] = "./scripts/package-artifacts.sh"
  ["package:publish-layout"] = "./scripts/build-publish-layout.sh"
  ["package:sync"] = "./scripts/sync-publish-layout.sh"
  ["fmt"] = "pnpm --filter @registry/docs fmt"
  ["lint"] = "pnpm --filter @registry/docs lint"
  ["check"] = "pnpm --filter @registry/docs check"
  ["test"] = "pnpm --filter @registry/docs test"
  ["resolve"] = "pkl project resolve . packages/target.*"
}
